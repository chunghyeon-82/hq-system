+    // Service Worker 준비 대기 (최대 10초)
+    const reg = await Promise.race([
+      navigator.serviceWorker.ready,
+      new Promise<never>((_, reject) =>
+        setTimeout(() => reject(new Error('Service Worker 준비 시간 초과')), 10000)
