rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────────
    function isSignedIn()  { return request.auth != null }
    function myUid()       { return request.auth.uid }
    function myData()      { return get(/databases/$(database)/documents/users/$(myUid())).data }
    function myRole()      { return myData().role }
    function myBizId()     { return myData().bizId }

    function isAdmin()     { return myRole() == 'ADMIN' }
    function isHQChief()   { return myRole() == 'HQ_CHIEF' }
    function isHQMember()  { return myRole() == 'HQ_MEMBER' }
    function isHQ()        { return myRole() in ['HQ_CHIEF', 'HQ_MEMBER'] }
    function isHQOrAdmin() { return isAdmin() || isHQ() }
    function isBizRep()    { return myRole() == 'BIZ_REP' }

    function canBroadcast() {
      return isAdmin() || isHQChief() ||
             (isHQMember() && myData().get('permissions', {}).get('canBroadcast', false) == true)
    }

    // ── 사용자 ─────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn()
      // 본인 프로필 수정 (role/permissions 변경 불가), 관리자는 전부 가능
      allow create: if isAdmin()
      allow update: if isAdmin()
                    || (myUid() == uid
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'permissions', 'bizId']))
      allow delete: if isAdmin()
    }

    // ── 사업장 ─────────────────────────────────────────
    match /businesses/{bizId} {
      allow read:   if isSignedIn()
      allow create, update, delete: if isAdmin()
    }

    // ── 전달 메시지 ────────────────────────────────────
    match /messages/{msgId} {
      // 읽기: 본부/관리자 전체, 사업장은 자기 것만, 1:1은 당사자만
      allow read: if isSignedIn() && (
        isHQOrAdmin()
        || (isBizRep() && (
              resource.data.targetBizIds.hasAny([myBizId()])
              || resource.data.authorUid == myUid()
              || resource.data.targetUid == myUid()
           ))
      )
      // 작성: broadcast는 본부/관리자, direct는 사업장도 가능
      allow create: if isSignedIn() && (
        (request.resource.data.type == 'broadcast' && canBroadcast())
        || (request.resource.data.type == 'direct'
            && (isHQOrAdmin() || isBizRep())
            && request.resource.data.authorUid == myUid())
      )
      // 수정: 본부/관리자(상태변경·답변), 사업장은 자기 receipt만
      allow update: if isSignedIn() && (
        isHQOrAdmin()
        || (isBizRep() && resource.data.targetBizIds.hasAny([myBizId()]))
        || (isBizRep() && resource.data.targetUid == myUid())
      )
      allow delete: if isAdmin()
    }

    // ── 운영본부 단체채팅 ──────────────────────────────
    match /hq_chat/{chatId} {
      allow read:   if isSignedIn() && isHQOrAdmin()
      allow create: if isSignedIn() && isHQOrAdmin()
                    && request.resource.data.authorUid == myUid()
      allow update, delete: if isAdmin()
    }

    // ── 공지사항 ────────────────────────────────────────
    match /notices/{noticeId} {
      allow read:   if isSignedIn()
      allow create: if canBroadcast()
                    && request.resource.data.authorUid == myUid()
      // 작성자 본인 또는 관리자만 수정/삭제
      allow update: if isAdmin()
                    || (isHQOrAdmin() && resource.data.authorUid == myUid())
      allow delete: if isAdmin()
                    || (isHQOrAdmin() && resource.data.authorUid == myUid())
    }

    // ── 캘린더 일정 ────────────────────────────────────
    match /events/{eventId} {
      // 본부/관리자: 전체 읽기, 사업장: 자기 것만
      allow read: if isSignedIn() && (
        isHQOrAdmin()
        || resource.data.targetBizIds.hasAny([myBizId()])
        || resource.data.ownerUid == myUid()
      )
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == myUid()
      allow update: if isSignedIn() && (
        isAdmin()
        || resource.data.ownerUid == myUid()
        // 사업장 대표는 자기 캘린더에 추가(addedToCalendar 필드만 변경)만 허용
        || (isBizRep() && resource.data.targetBizIds.hasAny([myBizId()])
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['addedBy', 'updatedAt']))
      )
      allow delete: if isAdmin()
                    || resource.data.ownerUid == myUid()
    }

    // ── 메시지 템플릿 ──────────────────────────────────
    match /templates/{tplId} {
      allow read:   if isSignedIn() && resource.data.ownerUid == myUid()
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == myUid()
      allow update, delete: if isSignedIn()
                    && resource.data.ownerUid == myUid()
    }

    // ── 사용자 설정 ────────────────────────────────────
    match /userSettings/{uid} {
      allow read, write: if isSignedIn() && myUid() == uid
    }

    // ── 사업장 순서 (개인별) ───────────────────────────
    match /bizOrder/{uid} {
      allow read, write: if isSignedIn() && myUid() == uid
    }

    // ── FCM 토큰 ────────────────────────────────────────
    match /fcmTokens/{uid} {
      allow read:  if isAdmin()
      allow write: if isSignedIn() && myUid() == uid
    }

    // ── 자동 삭제 로그 (스케줄러용) ────────────────────
    match /officialSeals/{sealId} {
      allow read: if isSignedIn() && isHQOrAdmin()
      allow create, update, delete: if isAdmin()
    }

    match /incomingDocs/{docId} {
      allow read: if isSignedIn() && isHQOrAdmin()
      allow create: if isSignedIn() && isHQOrAdmin()
      allow update: if isSignedIn() && isHQOrAdmin()
      allow delete: if isSignedIn() && (isAdmin() || resource.data.authorUid == myUid())
    }

    match /approvalLines/{lineId} {
      allow read, write: if isSignedIn() && isHQOrAdmin()
        && (request.method == 'read' || request.resource.data.ownerUid == myUid())
    }

    match /approvals/{docId} {
      allow read: if isSignedIn() && (
        isHQOrAdmin()
        || resource.data.authorUid == myUid()
        || resource.data.approvers.map(a, a.uid).hasAny([myUid()])
        || resource.data.finalApprover.uid == myUid()
        || resource.data.viewers.map(v, v.uid).hasAny([myUid()])
      )
      allow create: if isSignedIn() && isHQOrAdmin()
      allow update: if isSignedIn() && isHQOrAdmin()
      allow delete: if isSignedIn() && (isAdmin() || resource.data.authorUid == myUid())
    }

    match /approvalTemplates/{tplId} {
      allow read, write: if isSignedIn() && isHQOrAdmin()
    }

    match /emailContacts/{cId} {
      allow read, write: if isSignedIn() && myUid() == resource.data.ownerUid
      allow create: if isSignedIn()
    }

    match /recipientContacts/{cId} {
      allow read, write: if isSignedIn() && isHQOrAdmin()
        && (request.method == 'read' || request.resource.data.ownerUid == myUid())
    }

    match /deletionLogs/{logId} {
      allow read:  if isAdmin()
      allow write: if false  // Cloud Functions만 쓰기 가능
    }
  }
}
