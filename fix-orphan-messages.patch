+    const t = setTimeout(() => { if (!message) setNotFound(true) }, 5000)
+    return () => clearTimeout(t)
+  }, [message])
+
   if (!message) return (
     <AppShell title="전달 상세" back={isHQ ? '/businesses' : '/dashboard'}>
